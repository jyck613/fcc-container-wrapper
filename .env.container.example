# Minimal runtime config for isolated container wrapper
HOST=0.0.0.0
PORT=8082

# Local proxy auth token used by Claude CLI and curl checks
ANTHROPIC_AUTH_TOKEN=freecc

# Prevent browser auto-open from container
FCC_OPEN_BROWSER=false

# Keep messaging integrations disabled by default
MESSAGING_PLATFORM=none

# Provider configuration example: OpenRouter + NVIDIA free model
OPENROUTER_API_KEY=
MODEL=open_router/nvidia/nemotron-3-super-120b-a12b:free

# Optional local provider endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434
